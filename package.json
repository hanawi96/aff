{
  "name": "ctv-system",
  "version": "2.0.0",
  "description": "Hệ Thống Cộng Tác Viên - Mẹ & Bé (Turso Database)",
  "main": "worker.js",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "dev:backend": "wrangler dev --port 8787",
    "dev:frontend": "npx http-server public/shop -p 8080 -o",
    "build:css": "tailwindcss -i ./public/shop/assets/css/tailwind.input.css -o ./public/shop/assets/css/tailwind-built.css --minify",
    "watch:css": "tailwindcss -i ./public/shop/assets/css/tailwind.input.css -o ./public/shop/assets/css/tailwind-built.css --watch",
    "build:admin-css": "tailwindcss -c ./tailwind.admin.config.js -i ./public/assets/css/admin-tailwind.input.css -o ./public/assets/css/admin-tailwind-built.css --minify",
    "watch:admin-css": "tailwindcss -c ./tailwind.admin.config.js -i ./public/assets/css/admin-tailwind.input.css -o ./public/assets/css/admin-tailwind-built.css --watch",
    "build:admin-js": "node ./scripts/build-admin-js.mjs",
    "build:admin": "npm run build:admin-css && npm run build:admin-js",
    "build": "npm run build:css && npm run build:admin && echo 'CSS + admin bundle OK. Deploy public/ as usual.'",
    "deploy": "wrangler deploy",
    "deploy:pages": "wrangler pages publish public --project-name=ctv-system",
    "db:shell": "turso db shell vdt-yendev96",
    "db:backup": "turso db shell vdt-yendev96 .dump > database/backup.sql",
    "db:verify": "node scripts/verify-migration.js",
    "db:replicas": "turso db replicas list vdt-yendev96",
    "migrate:sheets": "node database/migrate-from-sheets.js",
    "logs": "wrangler tail",
    "test": "echo 'No tests yet'",
    "test:telegram": "node test-telegram-notification.js"
  },
  "keywords": [
    "referral",
    "affiliate",
    "ctv",
    "me-be",
    "cloudflare",
    "d1",
    "workers"
  ],
  "author": "hanawi96",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.17",
    "wrangler": "^3.0.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3"
  }
}
